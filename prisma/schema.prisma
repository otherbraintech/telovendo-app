generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(cuid())
  username        String           @unique
  usernameLower   String           @unique
  email           String?          @unique
  passwordHash    String
  name            String
  role            Role             @default(ESPECTADOR)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  botOrders       BotOrder[]
  genMarketplaces GenMarketplace[]
  projects        Project[]
}

model Project {
  id        String     @id @default(cuid())
  name      String
  nameLower String
  userId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  botOrders BotOrder[]
  user      User       @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model BotOrder {
  id                  String              @id @default(cuid())
  projectId           String
  userId              String
  type                OrderType           @default(MARKETPLACE)
  orderName           String              @default("Publicación Marketplace")
  socialNetwork       SocialNetwork       @default(FACEBOOK)
  quantity            Int                 @default(1)
  status              OrderStatus         @default(LISTA)
  // Campos específicos de Facebook Marketplace
  listingTitle        String?
  listingPrice        Decimal?            @db.Decimal(10, 2)
  listingCategory     MarketplaceCategory @default(VARIOS)
  listingCondition    ItemCondition       @default(NUEVO)
  listingDescription  String?
  listingAvailability ItemAvailability    @default(DISPONIBLE)
  listingType         MarketplaceType     @default(ARTICULO)
  listingCurrency     Currency            @default(BOLIVIANO)
  // Campos específicos para Vehículos
  vehicleYear         Int?
  vehicleMake         String?
  vehicleModel        String?
  vehicleMileage      Int?
  // Campos específicos para Propiedades
  propRooms           Int?
  propBathrooms       Int?
  propArea            Int?
  // Imágenes (almacenadas como URLs o paths)
  imageUrls           String[]            @default([])
  selectedDeviceIds   String[]            @default([])
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  project             Project             @relation(fields: [projectId], references: [id])
  user                User                @relation(fields: [userId], references: [id])
  genMarketplaces     GenMarketplace[]

  @@index([projectId, createdAt])
  @@index([userId, createdAt])
}

model GenMarketplace {
  id             Int           @id @default(autoincrement())
  orderId        String
  userId         String
  status         CommentStatus @default(PENDIENTE)
  deviceId       String?
  genTitle       String?
  genDescription String?
  imageUrls      String[]      @default([])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now())

  device   Device?  @relation(fields: [deviceId], references: [id])
  botOrder BotOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([orderId, createdAt])
}

model Device {
  id              String           @id @default(cuid())
  serial          String           @unique
  model           String?
  personName      String?
  label           String?
  triggerId       String?
  alias           String?
  estadoDb        String?
  redesSociales   Json?
  status          DeviceStatus     @default(LIBRE)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  genMarketplaces GenMarketplace[]

  @@map("dispositivos")
}

enum Role {
  ADMIN
  USUARIO
  ESPECTADOR
}

enum OrderType {
  MARKETPLACE
  COMENTARIO
  MEGUSTA
  COMPARTIR
  SEGUIMIENTO
  REPORTE
  GENLIVE
}

enum OrderStatus {
  LISTA
  GENERANDO
  GENERADA
  CANCELADA
  REINTENTAR
  COMPLETADA
  PAUSADA
}

enum SocialNetwork {
  FACEBOOK
  INSTAGRAM
  TIKTOK
  YOUTUBE
}

enum PostType {
  PUBLICACION
  IMAGEN
  VIDEO
  TEXTO
  PAGINA
  LIVE
  OTRO
}

enum MarketplaceCategory {
  VARIOS
  ALIMENTOS_Y_BEBIDAS
  ELECTRONICA
  ROPA_Y_ACCESORIOS
  HOGAR_Y_JARDIN
  JUGUETES_Y_JUEGOS
  DEPORTES
  INSTRUMENTOS_MUSICALES
  ARTE_Y_COLECCIONABLES
  LIBROS_Y_REVISTAS
  PELICULAS_Y_MUSICA
  VIDEOJUEGOS
  MASCOTAS
  ARTICULOS_BEBE
  HERRAMIENTAS
  JOYERIA
  BOLSOS_Y_ACCESORIOS
  ANTIGUEDADES
  SALUD_Y_BELLEZA
  MUEBLES
  ELECTRODOMESTICOS
  // Categorías de Vehículos
  AUTOS_Y_CAMIONETAS
  MOTOS
  STATION_WAGON
  SUB_BUS_Y_MINIBUS
  CAMIONES_Y_MAQUINARIA
  // Categorías de Propiedades
  ALQUILER_PROPIEDADES
  VENTA_PROPIEDADES
  TERRENOS_Y_LOTES
  LOCALES_Y_OFICINAS
}

enum ItemCondition {
  NUEVO
  USADO_COMO_NUEVO
  USADO_BUENO
  USADO_REGULAR
}

enum ItemAvailability {
  DISPONIBLE
  EN_POSESION_COMPRADOR
  OCULTO
}

enum CommentStatus {
  PENDIENTE
  PUBLICADO
  CANCELADO
  SINPUBLICAR
  PAUSADO
}

enum MarketplaceType {
  ARTICULO
  VEHICULO
  PROPIEDAD
}

enum DeviceStatus {
  OCUPADO
  LIBRE
  BLOQUEADO
  SIN_CUENTAS
}

enum Currency {
  BOLIVIANO
  DOLAR
}

model ChatSession {
  id             Int           @id @default(autoincrement())
  phone          String        @db.VarChar(20)
  customerName   String?       @db.VarChar(200)
  state          String?       @db.VarChar(40)
  patientId      Int?
  patientData    Json?
  ciAttempts     Int           @default(0)
  regAttempts    Int           @default(0)
  suspendedUntil DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  messages       ChatMessage[]

  @@index([phone])
  @@map("chat_sessions")
}

model ChatMessage {
  id          Int         @id @default(autoincrement())
  sessionId   Int
  role        String      @db.VarChar(10)
  content     String      @db.Text
  messageType String?     @db.VarChar(20)
  createdAt   DateTime    @default(now())
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("chat_messages")
}
